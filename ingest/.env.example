# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# Load it into your shell before running the bot, e.g.:  set -a; . ./.env; set +a

# From @BotFather after /newbot  (required for live mode)
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id  (required for live mode).
# Only messages from this id are processed — everyone else is ignored.
# Get it by messaging @userinfobot.
ALLOWED_TELEGRAM_USER_ID=

# The "brain" (python3 ingest/synthesize.py) needs ONE of the two keys below.
# synthesize.py auto-loads this file; OpenRouter wins if both are set.
# With neither key, run the brain from Claude Code instead ("refresh the
# brain" / the weekly review) — no key needed.

# Option A — OpenRouter (cheap, any model): https://openrouter.ai/keys
# Pick any chat model id from https://openrouter.ai/models; the pipeline
# validates the output shape itself, so no structured-output support needed.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nousresearch/hermes-4-405b

# Option B — Anthropic (anthropic SDK required: pip install anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
