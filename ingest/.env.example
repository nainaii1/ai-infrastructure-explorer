# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# Load it into your shell before running the bot, e.g.:  set -a; . ./.env; set +a

# From @BotFather after /newbot  (required for live mode)
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id  (required for live mode).
# Only messages from this id are processed — everyone else is ignored.
# Get it by messaging @userinfobot.
ALLOWED_TELEGRAM_USER_ID=

# Optional: only needed if you use Claude-assisted enrichment in review.py.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
